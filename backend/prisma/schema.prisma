generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     String   // ADMIN, DOCTOR, NURSE, CLEANING
  name     String?
  assignedPatients Patient[] @relation("DoctorPatients")
}

model Ward {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  capacity Int      @default(20)
  beds     Bed[]
}

model Patient {
  id         Int      @id @default(autoincrement())
  name       String
  age        Int
  dob        String
  gender     String
  allergies  String?
  history    String?
  medication          String?
  diagnosis           String?
  admissionDate       DateTime @default(now())
  healTimeDays        Int      @default(3)
  adminReviewRequested Boolean @default(false)
  assignedDoctorId    Int?
  assignedDoctor      User?    @relation("DoctorPatients", fields: [assignedDoctorId], references: [id])
  bedId               Int?     @unique
  bed                 Bed?     @relation(fields: [bedId], references: [id])
}

model Bed {
  id        Int      @id @default(autoincrement())
  number    String
  status    String   // AVAILABLE, OCCUPIED, RESERVED, NEEDS_CLEANING, IN_CLEANING
  wardId    Int
  ward      Ward     @relation(fields: [wardId], references: [id])
  patient   Patient?
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  createdAt DateTime @default(now())
}
